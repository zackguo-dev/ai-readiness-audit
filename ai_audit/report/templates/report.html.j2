<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>AI可読性診断レポート – {{ url }}</title>
  <style>
    /* WeasyPrint 注意: @media print は処理されない。全スタイルをグローバルに記述する */
    @page { size: A4; margin: 0; }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: system-ui, -apple-system, sans-serif; background: #fff; }

    .page {
      width: 595px;
      min-height: 842px;
      position: relative;
      padding: 56px 52px;
      page-break-after: always;
      page-break-inside: avoid;
      overflow: hidden;
    }
    .page:last-child { page-break-after: auto; }

    /* 全ページ共通: 下部アクセントバー */
    .page-bar {
      position: absolute;
      bottom: 0; left: 0; right: 0;
      height: 3px;
      background: #4F46E5;
    }
    /* 全ページ共通: ページ番号 */
    .page-num {
      position: absolute;
      bottom: 32px; right: 52px;
      font-size: 11px;
      color: #9090A0;
    }

    /* clearfix */
    .cf::after { content: ""; display: table; clear: both; }

    /* WeasyPrint では display:grid がサポートされる場合があるが、
       安全のため重要なレイアウトは float ベースで実装する */
    .check-block, .act, .check-row { page-break-inside: avoid; }

    /* ---- ブランドヘッダー ---- */
    .brand-logo {
      float: left;
      display: inline-block;
      width: 8px;
      height: 8px;
      border-radius: 2px;
      background: #4F46E5;
      margin-top: 2px;
      margin-right: 6px;
    }
    .brand-name {
      float: left;
      font-size: 12px;
      font-weight: 500;
      color: #4F46E5;
      text-transform: uppercase;
      letter-spacing: .08em;
    }
    .brand-confidential {
      float: right;
      font-size: 11px;
      color: #9090A0;
    }

    /* ---- スコアブロック ---- */
    .score-block {
      background: #F7F6FB;
      border-radius: 12px;
      padding: 32px;
      margin-bottom: 32px;
    }
    .score-col-left {
      float: left;
      width: 120px;
      text-align: center;
    }
    .score-num-large {
      font-size: 64px;
      font-weight: 500;
      line-height: 1;
      display: block;
    }
    .score-denom {
      font-size: 16px;
      color: #9090A0;
      display: block;
      margin-top: 4px;
    }
    .score-badge {
      display: inline-block;
      font-size: 11px;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: .04em;
      padding: 3px 10px;
      border-radius: 999px;
      margin-top: 10px;
    }
    .score-col-right {
      overflow: hidden;
      padding-left: 24px;
    }
    .score-h1 {
      font-size: 22px;
      font-weight: 500;
      color: #1A1A2E;
      margin-bottom: 10px;
    }
    .score-summary {
      font-size: 13px;
      color: #5A5A6E;
      line-height: 1.7;
      margin-bottom: 16px;
    }
    .score-meta {
      font-size: 12px;
      color: #9090A0;
    }

    /* ---- サマリーグリッド ---- */
    .summary-grid {
      margin-bottom: 32px;
    }
    .summary-card {
      float: left;
      width: 33.333%;
      padding: 8px;
    }
    .summary-card-inner {
      background: #F7F6FB;
      border-radius: 8px;
      padding: 16px;
      text-align: center;
    }
    .summary-num {
      font-size: 22px;
      font-weight: 500;
      display: block;
    }
    .summary-num-critical { color: #E24B4A; }
    .summary-num-warning  { color: #BA7517; }
    .summary-num-good     { color: #639922; }
    .summary-label {
      font-size: 11px;
      color: #9090A0;
      display: block;
      margin-top: 4px;
    }

    /* ---- チェックスコアテーブル ---- */
    .section-label {
      font-size: 11px;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: .06em;
      color: #9090A0;
      margin-bottom: 12px;
    }
    .check-score-row {
      border-bottom: 0.5px solid #F0EFF8;
      padding: 10px 0;
      overflow: hidden;
    }
    .check-score-row.last { border-bottom: none; }
    .check-score-right {
      float: right;
      width: 120px;
    }
    .score-bar-bg {
      height: 5px;
      border-radius: 3px;
      background: #EEEDF6;
      margin-bottom: 4px;
      overflow: hidden;
    }
    .score-bar-fill {
      height: 100%;
      border-radius: 3px;
    }
    .score-bar-num {
      font-size: 13px;
      font-weight: 500;
      text-align: right;
      display: block;
    }
    .check-score-left {
      overflow: hidden;
    }
    .check-name {
      font-size: 13px;
      font-weight: 500;
      color: #1A1A2E;
    }
    .primary-tag {
      font-size: 10px;
      background: #FCEBEB;
      color: #A32D2D;
      padding: 1px 5px;
      border-radius: 3px;
      margin-left: 6px;
      vertical-align: middle;
    }

    /* ---- P2 チェック行 ---- */
    .p2-title {
      font-size: 11px;
      font-weight: 500;
      text-transform: uppercase;
      color: #4F46E5;
      margin-bottom: 20px;
      letter-spacing: .04em;
    }
    .check-detail-row {
      border-bottom: 0.5px solid #F0EFF8;
      overflow: hidden;
    }
    .check-detail-row.last { border-bottom: none; }
    .check-detail-left {
      float: left;
      width: 140px;
      padding: 14px 16px 14px 0;
      border-right: 0.5px solid #F0EFF8;
    }
    .detail-bar-wrap {
      overflow: hidden;
      margin-top: 6px;
    }
    .detail-bar-bg {
      float: left;
      width: 60px;
      height: 4px;
      border-radius: 2px;
      background: #EEEDF6;
      margin-top: 4px;
      overflow: hidden;
    }
    .detail-bar-fill {
      height: 100%;
      border-radius: 2px;
    }
    .detail-score-num {
      float: left;
      font-size: 12px;
      font-weight: 500;
      margin-left: 8px;
      line-height: 1;
    }
    .check-detail-right {
      overflow: hidden;
      padding: 14px 0 14px 16px;
    }
    .detail-badge {
      font-size: 10px;
      font-weight: 500;
      border-radius: 999px;
      padding: 2px 7px;
      margin-bottom: 6px;
      display: inline-block;
    }
    .detail-finding {
      font-size: 12px;
      color: #5A5A6E;
      line-height: 1.65;
      overflow: hidden;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
    }

    /* ---- P3 アクション ---- */
    .p3-title {
      font-size: 11px;
      font-weight: 500;
      text-transform: uppercase;
      color: #4F46E5;
      margin-bottom: 20px;
      letter-spacing: .04em;
    }
    .act-section-label {
      font-size: 11px;
      font-weight: 500;
      color: #9090A0;
      text-transform: uppercase;
      letter-spacing: .04em;
      margin: 20px 0 10px;
    }
    .act-section-label.first { margin-top: 0; }
    .act {
      padding: 14px 16px;
      border-radius: 8px;
      margin-bottom: 8px;
      overflow: hidden;
    }
    .act-high { background: #FCEBEB; border-left: 3px solid #E24B4A; }
    .act-mid  { background: #FAEEDA; border-left: 3px solid #BA7517; }
    .act-low  { background: #F7F6FB; border-left: 3px solid #4F46E5; }
    .act-num {
      float: left;
      font-size: 18px;
      font-weight: 500;
      min-width: 24px;
    }
    .act-num-high { color: #A32D2D; }
    .act-num-mid  { color: #854F0B; }
    .act-num-low  { color: #4F46E5; }
    .act-body {
      overflow: hidden;
    }
    .act-text {
      font-size: 13px;
      font-weight: 500;
      color: #1A1A2E;
      line-height: 1.5;
      margin-bottom: 4px;
    }
    .act-badge-self {
      background: #EAF3DE;
      color: #27500A;
      font-size: 10px;
      padding: 1px 6px;
      border-radius: 3px;
      display: inline-block;
    }
    .act-badge-pro {
      background: #E6F1FB;
      color: #185FA5;
      font-size: 10px;
      padding: 1px 6px;
      border-radius: 3px;
      display: inline-block;
    }
    .act-cost {
      font-size: 11px;
      color: #9090A0;
      margin-left: 6px;
    }
  </style>
</head>
<body>

  <!-- ================================================================
       Page 1 — Summary
       ================================================================ -->
  <div class="page">

    <!-- ブランドヘッダー -->
    <div class="cf" style="margin-bottom:48px;">
      <span class="brand-logo"></span>
      <span class="brand-name">AI Readiness Audit</span>
      <span class="brand-confidential">Confidential</span>
    </div>

    <!-- スコアブロック -->
    <div class="score-block cf">
      <div class="score-col-left">
        <span class="score-num-large" style="color:{{ score_color }}">{{ score }}</span>
        <span class="score-denom">/100</span>
        <span class="score-badge"
              style="background:{{ score | score_bg }};color:{{ score | score_text }}">
          {{ status_label }}
        </span>
      </div>
      <div class="score-col-right">
        <div class="score-h1">AI可読性診断レポート</div>
        <div class="score-summary">{{ summary }}</div>
        <div class="score-meta">対象サイト：{{ url }} &nbsp;·&nbsp; 診断日：{{ date }}</div>
      </div>
    </div>

    <!-- サマリーグリッド -->
    <div class="summary-grid cf">
      <div class="summary-card">
        <div class="summary-card-inner">
          <span class="summary-num summary-num-critical">{{ count_critical }}</span>
          <span class="summary-label">重大な問題</span>
        </div>
      </div>
      <div class="summary-card">
        <div class="summary-card-inner">
          <span class="summary-num summary-num-warning">{{ count_warning }}</span>
          <span class="summary-label">要改善</span>
        </div>
      </div>
      <div class="summary-card">
        <div class="summary-card-inner">
          <span class="summary-num summary-num-good">{{ count_good }}</span>
          <span class="summary-label">良好</span>
        </div>
      </div>
    </div>

    <!-- チェックスコアテーブル -->
    <div class="section-label">診断項目スコア</div>
    {% for check in checks %}
    <div class="check-score-row cf{% if loop.last %} last{% endif %}">
      <div class="check-score-right">
        <div class="score-bar-bg">
          <div class="score-bar-fill"
               style="width:{{ check.score }}%;background:{{ check.score | score_color }}"></div>
        </div>
        <span class="score-bar-num" style="color:{{ check.score | score_color }}">{{ check.score }}</span>
      </div>
      <div class="check-score-left">
        <span class="check-name">{{ check.name }}</span>
        {% if check.is_primary %}<span class="primary-tag">最重要</span>{% endif %}
      </div>
    </div>
    {% endfor %}

    <div class="page-bar"></div>
    <div class="page-num">1 / 3</div>
  </div>

  <!-- ================================================================
       Page 2 — 診断詳細
       ================================================================ -->
  <div class="page">

    <div class="p2-title">診断詳細 — 項目別所見</div>

    {% for check in checks %}
    <div class="check-detail-row cf{% if loop.last %} last{% endif %}">
      <div class="check-detail-left">
        <span class="check-name">{{ check.name }}</span>
        {% if check.is_primary %}<span class="primary-tag">最重要</span>{% endif %}
        <div class="detail-bar-wrap cf">
          <div class="detail-bar-bg">
            <div class="detail-bar-fill"
                 style="width:{{ check.score }}%;background:{{ check.score | score_color }}"></div>
          </div>
          <span class="detail-score-num" style="color:{{ check.score | score_color }}">{{ check.score }}</span>
        </div>
      </div>
      <div class="check-detail-right">
        <span class="detail-badge"
              style="background:{{ check.score | score_bg }};color:{{ check.score | score_text }}">
          {% if check.score < 40 %}重大{% elif check.score < 70 %}要改善{% else %}良好{% endif %}
        </span>
        <div class="detail-finding">{{ check.finding }}</div>
      </div>
    </div>
    {% endfor %}

    <div class="page-bar"></div>
    <div class="page-num">2 / 3</div>
  </div>

  <!-- ================================================================
       Page 3 — 改善アクション
       ================================================================ -->
  <div class="page">

    <div class="p3-title">改善アクション — 優先度別ロードマップ</div>

    {% if actions_high %}
    <div class="act-section-label first">高優先度 — 早急に対応</div>
    {% for action in actions_high %}
    <div class="act act-high cf">
      <div class="act-num act-num-high">{{ loop.index }}</div>
      <div class="act-body">
        <div class="act-text">{{ action.text }}</div>
        <div>
          {% if action.type == "self" %}
          <span class="act-badge-self">自社で対応可</span>
          {% else %}
          <span class="act-badge-pro">Webサイトの制作会社へ依頼</span>
          {% endif %}
          {% if action.cost %}<span class="act-cost">（目安：{{ action.cost }}）</span>{% endif %}
        </div>
      </div>
    </div>
    {% endfor %}
    {% endif %}

    {% if actions_mid %}
    <div class="act-section-label{% if not actions_high %} first{% endif %}">中優先度 — 1〜3ヶ月以内に対応</div>
    {% for action in actions_mid %}
    <div class="act act-mid cf">
      <div class="act-num act-num-mid">{{ loop.index }}</div>
      <div class="act-body">
        <div class="act-text">{{ action.text }}</div>
        <div>
          {% if action.type == "self" %}
          <span class="act-badge-self">自社で対応可</span>
          {% else %}
          <span class="act-badge-pro">Webサイトの制作会社へ依頼</span>
          {% endif %}
          {% if action.cost %}<span class="act-cost">（目安：{{ action.cost }}）</span>{% endif %}
        </div>
      </div>
    </div>
    {% endfor %}
    {% endif %}

    {% if actions_low %}
    <div class="act-section-label{% if not actions_high and not actions_mid %} first{% endif %}">低優先度 — 将来への備え</div>
    {% for action in actions_low %}
    <div class="act act-low cf">
      <div class="act-num act-num-low">{{ loop.index }}</div>
      <div class="act-body">
        <div class="act-text">{{ action.text }}</div>
        <div>
          {% if action.type == "self" %}
          <span class="act-badge-self">自社で対応可</span>
          {% else %}
          <span class="act-badge-pro">Webサイトの制作会社へ依頼</span>
          {% endif %}
          {% if action.cost %}<span class="act-cost">（目安：{{ action.cost }}）</span>{% endif %}
        </div>
      </div>
    </div>
    {% endfor %}
    {% endif %}

    <!-- ノートボックス -->
    <div style="margin-top:28px;padding:14px 16px;background:#F7F6FB;border:0.5px solid #E6E4DD;border-radius:8px;">
      <div style="font-size:11px;font-weight:500;color:#4F46E5;text-transform:uppercase;letter-spacing:.04em;margin-bottom:6px;">本診断について</div>
      <div style="font-size:12px;color:#5A5A6E;line-height:1.7;">本レポートはWebサイトの「AIへの読み取られやすさ」を技術的に診断するものです。検索順位やコンテンツの品質は評価対象外です。llms.txtの効果は現時点で限定的であり、効果を保証するものではありません。</div>
    </div>

    <div class="page-bar"></div>
    <div class="page-num">3 / 3</div>
  </div>

</body>
</html>
